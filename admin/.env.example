# Admin panel — https://admin.ltyway.co.uk
# Copy to .env.local for local development.

DATABASE_URL=
BETTER_AUTH_SECRET=

# Local dev
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_MAIN_SITE_URL=http://localhost:3000

# Production (Vercel admin project — one value per field, no extra lines)
# BETTER_AUTH_URL=https://admin.ltyway.co.uk
# NEXT_PUBLIC_BETTER_AUTH_URL=https://admin.ltyway.co.uk
# NEXT_PUBLIC_MAIN_SITE_URL=https://ltyway.co.uk

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Local redirect URI:     http://localhost:3001/api/auth/callback/google
# Production redirect URI: https://admin.ltyway.co.uk/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel Blob (car image uploads from admin)
BLOB_READ_WRITE_TOKEN=
